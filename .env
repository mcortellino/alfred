# Alfred TTS Configuration
# This file contains environment variables for the Alfred home assistant

# TTS Engine: "kokoro" (default) or "piper"
ALFRED_TTS_ENGINE=piper

# Kokoro TTS settings (when ALFRED_TTS_ENGINE=kokoro)
# Voice preferences: auto, female, male
ALFRED_TTS_VOICE_PREFERENCE=male

# Piper TTS settings (when ALFRED_TTS_ENGINE=piper)
# Voice model name (e.g., en_US-lessac-medium, it_IT-riccardo-x_low)
ALFRED_TTS_MODEL=it_IT-riccardo-x_low

# Path to Piper voice model directory or file (optional)
# If not set, looks in ~/.local/share/piper/voices/
# Example for Windows: D:\git\alfred\backend\models\tts\pipertts\riccardo
# Example for Linux/Mac: /home/user/.local/share/piper/voices
# ALFRED_TTS_VOICE_PATH=

# Disable voice output (0=enabled, 1=disabled)
ALFRED_NO_VOICE=0

# Kokoro models directory (advanced)
# ALFRED_TTS_MODELS_DIR=

# Auto-download Kokoro models (1=enabled, 0=disabled)
ALFRED_TTS_AUTO_DOWNLOAD=0

# Wake word name
ALFRED_WAKEWORD_NAME=alfred

# Log level (optional)
# LOG_LEVEL=INFO
